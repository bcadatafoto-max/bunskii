# ═══════════════════════════════════════════════════════════════
# BUNSKII - Hermes Agent Configuration
# Copy file ini ke .env dan isi semua value-nya
# cp .env.example .env && nano .env
# ═══════════════════════════════════════════════════════════════

# ─── TELEGRAM BOT ───────────────────────────────────────────
# Dapet dari @BotFather di Telegram
# Panduan: docs/02-setup-telegram.md
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram User ID lo (biar cuma lo yang bisa perintah bot)
# Dapet dari @userinfobot di Telegram
TELEGRAM_ALLOWED_USERS=your_telegram_user_id

# ─── LLM PROVIDER ──────────────────────────────────────────
# Pilih salah satu (atau isi semua, Hermes bisa switch):

# OpenRouter (rekomen - multi-model, bisa Claude/Gemini/DeepSeek/dll)
# Daftar: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# Google Gemini (gratis 1500 req/hari)
# Daftar: https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude (opsional - paling bagus coding)
# Daftar: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# DeepSeek (opsional - murah, coding bagus)
# Daftar: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ─── MODEL DEFAULT ──────────────────────────────────────────
# Model yang dipake pas pertama kali chat
# Contoh: google/gemini-2.5-flash (gratis via OpenRouter)
#         anthropic/claude-sonnet-4-20250514
#         deepseek/deepseek-chat
#         nousresearch/hermes-3-llama-3.1-405b
DEFAULT_MODEL=google/gemini-2.5-flash

# ─── DOMAIN & TUNNEL ───────────────────────────────────────
# Domain/subdomain yang mau dipake (misal: hermes.domainlo.com)
DOMAIN=hermes.bunskii.biz.id

# Cloudflare Tunnel Token
# Dapet dari: Cloudflare Zero Trust Dashboard → Tunnels → Create
# Panduan: docs/03-setup-cloudflare.md
CLOUDFLARE_TUNNEL_TOKEN=eyJhxxxxxxxxxxxxxxxx

# ─── HERMES SETTINGS ───────────────────────────────────────
# Port internal gateway (biasanya gak perlu diubah)
HERMES_PORT=8642

# Timezone (buat cron & scheduled tasks)
TZ=Asia/Jakarta

# Agent name (muncul di Telegram)
AGENT_NAME=Bunskii

# ─── GITHUB (OPSIONAL) ─────────────────────────────────────
# Kalo mau agent bisa push code ke GitHub
# Generate: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=your_github_username

# ─── ADVANCED (biasanya gak perlu diubah) ───────────────────
# Browser automation (Playwright) - aktifin kalo RAM >= 8GB
ENABLE_BROWSER=true

# Voice mode - aktifin kalo mau kirim voice memo ke bot
ENABLE_VOICE=false

# Max concurrent tasks
MAX_TASKS=3

# Log level (debug, info, warn, error)
LOG_LEVEL=info
